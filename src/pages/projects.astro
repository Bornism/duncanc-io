---
import Base from '../layouts/Base.astro';
---
<Base title="Projects">
  <div class="page-wrapper">
    <div class="container">
      <h2 style="font-family:var(--font-serif);font-size:2rem;margin-bottom:6px;">Projects &amp; Builds</h2>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:36px;">Things I've built in my free time. Source on GitHub.</p>

      <div class="project-grid">
        <div class="project-card">
          <div class="project-icon">📊</div>
          <h3>FinDash</h3>
          <p>Personal finance dashboard with real-time spending, investment tracking, and net worth aggregation.</p>
          <div class="project-stack">
            <span class="stack-badge">Next.js</span>
            <span class="stack-badge">Plaid API</span>
            <span class="stack-badge">TypeScript</span>
          </div>
        </div>
        <div class="project-card">
          <div class="project-icon">🤖</div>
          <h3>AI News Digest</h3>
          <p>Daily email digest that summarizes top tech and finance news using Gemini and a custom classifier.</p>
          <div class="project-stack">
            <span class="stack-badge">Python</span>
            <span class="stack-badge">Gemini API</span>
          </div>
        </div>
        <div class="project-card">
          <div class="project-icon">📈</div>
          <h3>Stock Screener</h3>
          <p>Custom screener for value and growth metrics with automated alerts via Telegram.</p>
          <div class="project-stack">
            <span class="stack-badge">Python</span>
            <span class="stack-badge">Streamlit</span>
          </div>
        </div>
        <div class="project-card" style="border-style:dashed;">
          <div class="project-icon">🚧</div>
          <h3>More coming soon…</h3>
          <p>Always building. Follow on GitHub to stay updated on what's in progress.</p>
        </div>
      </div>
    </div>
  </div>
</Base>
