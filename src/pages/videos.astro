---
import Base from '../layouts/Base.astro';
---
<Base title="Videos">
  <div class="page-wrapper">
    <div class="container">
      <h2 style="font-family:var(--font-serif);font-size:2rem;margin-bottom:6px;">Videos</h2>
      <p style="color:var(--muted);font-size:.9rem;margin-bottom:28px;">
        YouTube content on tech builds, finance, and engineering.
        <span class="coming-soon">🎬 Launching soon</span>
      </p>

      <div class="callout">
        <strong>Channel coming soon.</strong> I'm putting together my first batch of videos.
        <a href="https://youtube.com/@cduncan" target="_blank" style="color:var(--accent);">Subscribe on YouTube</a> to get notified when they drop.
      </div>

      <p class="section-label">Planned Series</p>
      <div class="video-list">
        <div class="video-card">
          <div class="video-thumb">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <div class="video-info">
            <h3>Build With Me: FinDash from zero to deploy</h3>
            <p>Full walkthrough of building a personal finance dashboard · <em>Coming soon</em></p>
          </div>
        </div>
        <div class="video-card">
          <div class="video-thumb">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <div class="video-info">
            <h3>How I invest my Google salary</h3>
            <p>Honest breakdown of my index fund strategy · <em>Coming soon</em></p>
          </div>
        </div>
        <div class="video-card">
          <div class="video-thumb">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <div class="video-info">
            <h3>AI tools every engineer should know in 2025</h3>
            <p>My daily toolchain for 10x productivity · <em>Coming soon</em></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>
